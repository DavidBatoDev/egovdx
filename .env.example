# eGovDX Local — copy to .env.local and fill in.
# .env.local is gitignored. Never commit real values.
#
# Variable names and authentication requirements are based on
# docs/API_Reference.md. API credentials remain server-only unless explicitly
# marked NEXT_PUBLIC_ for a browser SDK.

# ---------------------------------------------------------------- app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------ supabase
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://fvvqesqjerhtebdifhun.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — must never be prefixed NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Management API token for the Supabase MCP server in .mcp.json. That file
# expands ${SUPABASE_ACCESS_TOKEN} from your shell environment, not from here.
SUPABASE_ACCESS_TOKEN=

# --------------------------------------------------------- session signing
# openssl rand -base64 32
SESSION_SECRET=

# ---------------------------------------------------------------- browser QA
# Optional. Defaults to http://localhost:3000 when unset.
QA_BASE_URL=http://localhost:3000

# --------------------------------------------------------------- eGovPH
# live = hit the sandbox · mock = serve fixtures.
EGOV_SSO_MODE=mock
EGOV_EVERIFY_MODE=mock
EGOV_LIVENESS_MODE=mock
EGOV_EMESSAGE_MODE=mock
EGOV_AI_MODE=mock
EGOV_PAY_MODE=mock
EGOV_CHAIN_MODE=mock

# --- eGOV PH · SSO -----------------------------------------------------
# The app receives an upstream exchange_code, then POST /api/token uses it with
# SSO_AUTHENTICATION, partner_code, and partner_secret. All SSO credentials stay server-side.
EGOV_SSO_BASE_URL=
EGOV_SSO_PARTNER_CODE=
EGOV_SSO_PARTNER_SECRET=

# --- #NationalID · eVerify --------------------------------------------
# POST /api/auth requires client_id + client_secret.
EGOV_EVERIFY_BASE_URL=
EGOV_EVERIFY_CLIENT_ID=
EGOV_EVERIFY_CLIENT_SECRET=
# Public SDK key for window.eKYC().start({ pubKey }) — browser-side.
NEXT_PUBLIC_EVERIFY_LIVENESS_PUBLIC_KEY=

# --- FACE LIVENESS (standalone REST) -----------------------------------
# Header: x-api-key (lowercase). Accept only SUCCEEDED with score >= 95.0.
EGOV_LIVENESS_BASE_URL=
EGOV_LIVENESS_API_KEY=

# --- eMessage ----------------------------------------------------------
# Header: X-EMESSAGE-Auth · body { number, message }.
EGOV_EMESSAGE_BASE_URL=
EGOV_EMESSAGE_API_TOKEN=

# --- eGov AI -----------------------------------------------------------
# POST /api/v1/egov/integration/token requires access_code.
EGOV_AI_BASE_URL=
EGOV_AI_ACCESS_CODE=

# --- eGOV PAY ----------------------------------------------------------
# Header: X-eGovPay-Token. A test_-prefixed token runs in test mode.
# Payment creation also requires settlement_template_uuid and a per-request
# HMAC-SHA256 digest of "<amount>|<txnid>" keyed with this token.
EGOV_PAY_BASE_URL=
EGOV_PAY_API_TOKEN=
EGOV_PAY_SETTLEMENT_TEMPLATE_UUID=

# --- eGOV chain --------------------------------------------------------
# Chain ID 13371 (0x343b) · gas price 0. No auth is documented for JSON-RPC.
EGOV_CHAIN_RPC_URL=https://hackathon-blockchain.e.gov.ph
