# eGovDX Local — copy to .env.local and fill in.
# .env.local is gitignored. Never commit real values.

# ---------------------------------------------------------------- app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------ supabase
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — must never be prefixed NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------------------- eGovPH
# Per-service mode: "live" hits the sandbox, "mock" serves fixtures.
# Flip any service to mock if the sandbox misbehaves during the demo.
EGOV_SSO_MODE=live
EGOV_EVERIFY_MODE=live
EGOV_LIVENESS_MODE=live
EGOV_EMESSAGE_MODE=live
EGOV_AI_MODE=live
EGOV_PAY_MODE=mock
EGOV_CHAIN_MODE=mock

# eGOV PH — Single sign-on
EGOV_SSO_BASE_URL=
EGOV_SSO_CLIENT_ID=
EGOV_SSO_CLIENT_SECRET=
EGOV_SSO_REDIRECT_URI=http://localhost:3000/api/auth/egov/callback

# #NationalID | eVerify
EGOV_EVERIFY_BASE_URL=
EGOV_EVERIFY_CLIENT_ID=
EGOV_EVERIFY_CLIENT_SECRET=

# FACE LIVENESS
EGOV_LIVENESS_BASE_URL=
EGOV_LIVENESS_API_KEY=

# eMessage
EGOV_EMESSAGE_BASE_URL=
EGOV_EMESSAGE_API_KEY=

# eGov AI
EGOV_AI_BASE_URL=
EGOV_AI_CLIENT_ID=
EGOV_AI_CLIENT_SECRET=

# eGOV PAY  (endpoints undocumented — confirm via scripts/probe.ts before going live)
EGOV_PAY_BASE_URL=
EGOV_PAY_API_KEY=

# eGOV chain (Hyperledger Besu over JSON-RPC)
EGOV_CHAIN_RPC_URL=
EGOV_CHAIN_PRIVATE_KEY=

# --------------------------------------------------------- session signing
# Any random 32+ char string:  openssl rand -base64 32
SESSION_SECRET=
