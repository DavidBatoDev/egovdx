# eGovDX Local — copy to .env.local and fill in.
# .env.local is gitignored. Never commit real values.
#
# Variable names below match docs/API_Reference.md exactly. Each service
# authenticates differently — check the reference before assuming bearer auth.

# ---------------------------------------------------------------- app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------ supabase
# Project: egovdx (fvvqesqjerhtebdifhun) · ap-southeast-1
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://fvvqesqjerhtebdifhun.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — must never be prefixed NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Management API token for the Supabase MCP servers in .mcp.json and
# .codex/config.toml. Both clients read the value from the shell environment,
# not from this dotenv file.
# Set it with `setx SUPABASE_ACCESS_TOKEN "sbp_..."`, then fully restart Codex
# and your terminal. Never commit the token itself.
SUPABASE_ACCESS_TOKEN=

# --------------------------------------------------------- session signing
# openssl rand -base64 32
SESSION_SECRET=

# ---------------------------------------------------------------- browser QA
# Optional. Defaults to http://localhost:3000 when unset.
QA_BASE_URL=http://localhost:3000

# --------------------------------------------------------------- eGovPH
# live = hit the sandbox · mock = serve fixtures.
# Switch a service to mock the moment it misbehaves during a recording.
EGOV_SSO_MODE=mock
EGOV_EVERIFY_MODE=mock
EGOV_LIVENESS_MODE=mock
EGOV_EMESSAGE_MODE=mock
EGOV_AI_MODE=mock
EGOV_PAY_MODE=mock
EGOV_CHAIN_MODE=mock

# --- eGOV PH · SSO -----------------------------------------------------
# Widget-based: the browser widget returns an exchange_code, which the server
# swaps for a token using partner_code + partner_secret. NOT an OAuth redirect.
EGOV_SSO_BASE_URL=
EGOV_SSO_PARTNER_CODE=
EGOV_SSO_PARTNER_SECRET=
# Public — used by the browser widget. STAGING unless told otherwise.

# --- #NationalID · eVerify --------------------------------------------
# /api/query REQUIRES a face_liveness_session_id from the Face Liveness SDK.
EGOV_EVERIFY_BASE_URL=
EGOV_EVERIFY_CLIENT_ID=
EGOV_EVERIFY_CLIENT_SECRET=
# Public SDK key for window.eKYC().start({ pubKey }) — browser-side.
NEXT_PUBLIC_EVERIFY_LIVENESS_PUBLIC_KEY=

# --- FACE LIVENESS (standalone REST) -----------------------------------
# Header: x-api-key (lowercase). Accept only SUCCEEDED with score >= 95.0
EGOV_LIVENESS_BASE_URL=
EGOV_LIVENESS_API_KEY=

# --- eMessage ----------------------------------------------------------
# Header: X-EMESSAGE-Auth · body { number, message } · returns 201
EGOV_EMESSAGE_BASE_URL=
EGOV_EMESSAGE_API_TOKEN=
EGOV_EMESSAGE_TEST_NUMBER=

# --- eGov AI -----------------------------------------------------------
# Token from access_code. 200 CREDITS TOTAL — check GET /credits before demos.
EGOV_AI_BASE_URL=
EGOV_AI_ACCESS_CODE=
OPENAI_API_KEY=
OPENAI_STUDIO_MODE=live
OPENAI_STUDIO_MODEL=gpt-5.4-mini

# --- eGOV PAY ----------------------------------------------------------
# Header: X-eGovPay-Token. A test_-prefixed token runs in test mode.
# Every request needs digest = HMAC-SHA256("<amount>|<txnid>", token)
EGOV_PAY_BASE_URL=
EGOV_PAY_API_TOKEN=
EGOV_PAY_SETTLEMENT_TEMPLATE_UUID=

# --- eGOV chain --------------------------------------------------------
# Chain ID 13371 (0x343b) · gas price 0 · explorer hackathon-explorer.e.gov.ph.
# The API reference documents no authentication for JSON-RPC.
EGOV_CHAIN_RPC_URL=https://hackathon-blockchain.e.gov.ph
EGOV_CHAIN_PRIVATE_KEY=
